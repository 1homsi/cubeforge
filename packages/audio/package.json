  },
  "keywords": [
    "game-engine",
    "audio",
    "web-audio",
    "cubeforge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  },
  "private": true,
