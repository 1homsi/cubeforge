{
  "name": "@cubeforge/react",
  "version": "0.0.1",
  "description": "React components and hooks for building 2D browser games with Cubeforge",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@cubeforge/core": "workspace:*",
    "@cubeforge/input": "workspace:*",
    "@cubeforge/renderer": "workspace:*",
    "@cubeforge/physics": "workspace:*"
  },
  "keywords": ["game-engine", "react", "2d", "browser-game", "cubeforge"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  }
}
