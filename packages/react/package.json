{
  "name": "cubeforge",
  "version": "0.1.0",
  "description": "React-first 2D browser game engine",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.mts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@cubeforge/core": "workspace:*",
    "@cubeforge/input": "workspace:*",
    "@cubeforge/physics": "workspace:*",
    "@cubeforge/renderer": "workspace:*",
    "tsup": "^8.0.0"
  },
  "keywords": [
    "game-engine",
    "react",
    "2d",
    "browser-game",
    "cubeforge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  }
}
