{
  "name": "@cubeforge/renderer",
  "version": "0.0.1",
  "description": "WebGL2 instanced renderer for Cubeforge",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cubeforge/core": "workspace:*"
  },
  "keywords": [
    "game-engine",
    "renderer",
    "canvas",
    "cubeforge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  },
  "private": true
}
