{
  "name": "@cubeforge/renderer",
  "version": "0.0.1",
  "description": "WebGL2 instanced renderer for Cubeforge",
  "main": "./dist/index.mjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cubeforge/core": "workspace:*"
  },
  "keywords": [
    "game-engine",
    "renderer",
    "canvas",
    "cubeforge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  },
  "private": true,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  }
}
