{
  "name": "@cubeforge/physics",
  "version": "0.0.1",
  "description": "AABB physics with fixed timestep and spatial broadphase for Cubeforge",
  "main": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@cubeforge/core": "workspace:*"
  },
  "keywords": ["game-engine", "physics", "aabb", "cubeforge"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  }
}
