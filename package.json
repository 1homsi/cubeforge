{
  "name": "cubeforge",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*", "examples/*"],
  "scripts": {
    "dev": "bun run --cwd examples/demo dev",
    "dev:platformer": "bun run --cwd examples/platformer dev",
    "build": "bun run --filter './packages/*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0"
  }
}
