{
  "name": "@cubeforge/context",
  "version": "0.0.1",
  "description": "Shared React context for Cubeforge integrations (internal)",
  "main": "./dist/index.mjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cubeforge/core": "workspace:*",
    "@cubeforge/input": "workspace:*",
    "@cubeforge/physics": "workspace:*",
    "@cubeforge/renderer": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  },
  "private": true,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  }
}
