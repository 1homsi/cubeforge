{
  "name": "@cubeforge/editor",
  "version": "0.1.0",
  "description": "Visual scene editor UI for CubeForge games",
  "main": "./dist/index.mjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cubeforge/context": "workspace:*",
    "@cubeforge/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  },
  "keywords": [
    "game-engine",
    "react",
    "editor",
    "cubeforge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1homsi/cubeforge"
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  }
}
